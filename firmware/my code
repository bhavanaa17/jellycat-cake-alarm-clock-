#include <Adafruit_GFX.h>
#include <Adafruit_ST7789.h>
#include <SPI.h>

#define TFT_SCLK 21
#define TFT_MOSI 20
#define TFT_RST 10
#define TFT_DC 8
#define TFT_CS 7
#define TFT_BL 6
Adafruit_ST7789 tft = Adafruit_ST7789(TFT_CS, TFT_DC, TFT_MOSI, TFT_SCLK, TFT_RST);

int hours = 14;
int minutes = 30;
int seconds = 0;

unsigned long lastTick = 0;

void setup() {
  pinMode(TFT_BL, OUTPUT);
  digitalWrite(TFT_BL, HIGH);

  tft.init(284, 76);
  tft.setColRowStart(82, 18);
  tft.setRotation(2);
  tft.setTextColor(ST77XX_WHITE);

  lastTick = millis();

  tft.fillScreen(ST77XX_BLACK);
  tft.setCursor(10, 20);
  tft.setTextSize(3);
  char buf[6];
  sprintf(buf, "%02d:%02d", hours, minutes);
  tft.print(buf);
}

void loop() {
  if (millis() - lastTick >= 1000) {
    lastTick = millis();
    seconds++;
    if (seconds >= 60) {
      seconds = 0;
      minutes++;
      if (minutes >= 60) {
        minutes = 0;
        hours++;
      }

      tft.fillScreen(ST77XX_BLACK);
      tft.setCursor(10, 20);
      tft.setTextSize(3);
      char buf[6];
      sprintf(buf, "%02d:%02d", hours, minutes);
      tft.print(buf);
    }
  }
}
